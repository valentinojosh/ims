ilePath":"64","messages":"65","suppressedMessages":"66","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"67"},{"filePath":"68","messages":"69","suppressedMessages":"70","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"71"},{"filePath":"72","messages":"73","suppressedMessages":"74","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"75","messages":"76","suppressedMessages":"77","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"78"},{"filePath":"79","messages":"80","suppressedMessages":"81","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"82"},{"filePath":"83","messages":"84","suppressedMessages":"85","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"86"},{"filePath":"87","messages":"88","suppressedMessages":"89","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"90"},{"filePath":"91","messages":"92","suppressedMessages":"93","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"94"},{"filePath":"95","messages":"96","suppressedMessages":"97","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"98"},{"filePath":"99","messages":"100","suppressedMessages":"101","errorCount":0,"fatalErrorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"102"},{"filePath":"103","messages":"104","suppressedMessages":"105","errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"106"},{"filePath":"107","messages":"108","suppressedMessages":"109","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"110","messages":"111","suppressedMessages":"112","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"113","messages":"114","suppressedMessages":"115","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"116","messages":"117","suppressedMessages":"118","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"119","messages":"120","suppressedMessages":"121","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"122","messages":"123","suppressedMessages":"124","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"125","messages":"126","suppressedMessages":"127","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/josh/Documents/GitHub/ims/src/index.js",[],[],"/Users/josh/Documents/GitHub/ims/src/App.js",[],[],"/Users/josh/Documents/GitHub/ims/src/IMSindex.js",["128","129","130","131"],[],"import Logo from \"./images/SpecialRecLogo.png\";\nimport background from \"./images/bg-01.jpg\";\n import \"./css/util.css\"\n import \"./css/index.css\"\n import \"./fonts/font-awesome-4.7.0/css/font-awesome.min.css\"\n import \"./fonts/iconic/css/material-design-iconic-font.min.css\"\nimport React, { useState } from \"react\";\nimport { Link } from \"react-router-dom\";\n\nconst LoginPage = () => {\n    // React States\n  const [errorMessages, setErrorMessages] = useState({});\n  const [isSubmitted, setIsSubmitted] = useState(false);\n\n\n  // User Login info\n  const database = [\n    {\n      username: \"user1\",\n      password: \"pass1\"\n    },\n    {\n      username: \"test\",\n      password: \"test\"\n    }\n  ];\n\n  //Error Messages\n  const errors = {\n    uname: \"Invalid Username\",\n    pass: \"Invalid Password\"\n  };\n\n  const handleSubmit = (event) => {\n    //Prevent page reload\n    event.preventDefault();\n\n    setIsSubmitted(true);\n    localStorage.setItem(\"isAuthenticated\", \"true\");\n    window.location.href = \"/admin\";\n  };\n\n  // Generate JSX code for error message\n  const renderErrorMessage = (name) =>\n      name === errorMessages.name && (\n          <div className=\"input100Error\">{errorMessages.message}</div>\n      );\n\n  // JSX code for login form\n  const renderForm = (\n      <form onSubmit={handleSubmit}>\n\n          <div className=\"tempNote\">\n                      <span style={{ color: 'red', textDecoration: 'underline' }}>\n                        Note\n                      </span>\n              <br />\n              Server down due to cost. Frontend view. Use \"test\" for both username and password to login as admin.\n              <br />\n          </div>\n\n        <div className=\"wrap-input100 validate-input\" data-validate=\"Enter username\">\n          <input className=\"input100\" type=\"text\" name=\"uname\" required placeholder=\"Username\" />\n          <span className=\"focus-input100\" data-placeholder=\"&#xf207;\" />\n          {renderErrorMessage(\"uname\")}\n        </div>\n\n        <div className=\"wrap-input100 validate-input\" data-validate=\"Enter password\">\n          <input className=\"input100\" type=\"password\" name=\"pass\" required placeholder=\"Password\" />\n          <span className=\"focus-input100\" data-placeholder=\"&#xf191;\" />\n          {renderErrorMessage(\"pass\")}\n        </div>\n        <div className=\"button-container\">\n\n\n          <div className=\"container-login100-form-btn\">\n\n\n            <button className=\"custombutton\" type=\"submit\" >\n              Login as Admin\n            </button>\n\n          </div>\n          <br>\n\n          </br>\n          <div className=\"container-login100-form-btn\">\n            <Link to=\"/Employee\">\n              <button className=\"custombutton\">\n                Continue as Employee\n              </button>\n            </Link>\n          </div>\n        </div>\n      </form>\n\n  );\n\n  return (\n\n\n      <div className=\"limiter\">\n        <div className=\"container-login100\" style={{backgroundImage: `url(${background})`}}>\n          <div className=\"wrap-login101\">\n            <div className=\"login100-form validate-form\">\n              <span className=\"login100-form-logo\">\n                <img src={Logo} width={120} height={120} />\n              </span>\n              <span className=\"login100-form-title p-b-34 p-t-27\">\n                <div className=\"greenUnderline\">Admin Log In</div>\n              </span>\n\n              {isSubmitted ? <div className=\"login100-form-title p-b-34 p-t-27\">Log In Successful </div> : renderForm}\n\n            </div>\n          </div>\n        </div>\n      </div>\n     );\n}\n \nexport default LoginPage;","/Users/josh/Documents/GitHub/ims/src/Employee.js",[],[],"/Users/josh/Documents/GitHub/ims/src/Settings.js",[],[],"/Users/josh/Documents/GitHub/ims/src/createAdmin.js",["132","133"],[],"import \"./css/createAdmin.css\"\nimport \"./images/icons/FVSRA_ICON.png\"\nimport logo from \"./forms/PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport React, {useState} from \"react\";\nimport {Link, useNavigate} from \"react-router-dom\";\nimport background from \"./images/bg-01.jpg\";\nimport bcrypt from 'bcryptjs';\n\nconst salt = bcrypt.genSaltSync(3)\n\nconst CreateAdmin = () => {\n\n    const [username, setUsername] = useState('');\n    const [password, setPassword] = useState('');\n    const hashedPassword = bcrypt.hashSync(password, salt) ;\n\n    const navigate = useNavigate() //Like going back and forward in \"history\"/back from the previous or next page\n\n\n    const handleSubmit = (e) => { //Handles the onSubmit action of the log\n        e.preventDefault();\n\n        let minorInjuryLogObj = {\n            \"username\": username,\n            \"password\": hashedPassword,\n        }\n\n        fetch('https://api.foxvalleyspecialrec.com/fvsra/auth', {\n            method: 'POST',\n            headers: { \"Content-Type\": \"application/json\" },\n            body: JSON.stringify(minorInjuryLogObj)\n        }).then(() => {\n\n           alert(\"Account Created\");\n\n        })\n\n    }\n\n    return (\n\n        <div>\n\n            <form onSubmit={handleSubmit}>\n                <div className=\"container-login100\" style={{backgroundImage: `url(${background})`}}>\n                    <div className=\"wrap-login101\">\n\n                         <span className=\"login100-form-title p-b-34 p-t-27\">\n                        <div className=\"greenUnderline\">New Admin Account</div>\n                       </span>\n\n\n\n                <input className=\"input100Create\" type=\"text\" placeholder=\"Enter Username\" name=\"uname\" value={username} onChange={(e) => setUsername(e.target.value)} id=\"username\"  required />\n                <input className=\"input100Create\" type=\"password\" placeholder=\"Enter Password\" name=\"psw\" value={password} onChange={(e) => setPassword(e.target.value)} id=\"password\"  required/>\n\n                    <div className=\"centerButton\">\n                        <button className=\"createbutton\">Submit</button>\n                    </div>\n\n                    </div>\n\n\n\n                    <Link to=\"/admin/settings\">\n                        <button className=\"LogoutButton\"  >\n                            Return\n                        </button>\n                    </Link>\n\n                    </div>\n            </form>\n        </div>\n    );\n}\n\nexport default CreateAdmin;","/Users/josh/Documents/GitHub/ims/src/deleteAdmin.js",["134"],[],"import UseFetch from \"./UseFetch\";\nimport moment from 'moment';\nimport { confirm } from \"react-confirm-box\";\n\nconst DeleteAdmin = () => {\n\n    const { data: logs, isPending, error} = UseFetch('https://api.foxvalleyspecialrec.com/fvsra/auth');\n\n    const handleDelete = async (e, user_id) => {\n        e.preventDefault();\n        const result = await confirm(\"Are you sure? This action cannot be undone.\");\n        if (result) {\n            fetch('https://api.foxvalleyspecialrec.com/fvsra/auth/' + user_id, {\n                method: 'DELETE'\n            }).then(() => {\n                alert(\"Account:\" + user_id + \" Deleted\");\n                window.location.reload(false);\n            })\n            return;\n        }\n    }\n\n\n\n    return (\n        <div className=\"theHeader\">\n            {error && <div>{error}</div>}\n            {isPending && <div>Loading...</div>}\n            {logs &&\n            <div>\n                <div>\n                    <h2 className=\"viewMinorInjuryLogHeader\">List of Accounts</h2>\n                </div>\n\n                <div>\n                    <table className=\"tableMinorInjuryLog\">\n                        <thead>\n                        <tr>\n                            <th>User ID</th>\n                            <th>Username</th>\n\n                            <th>Actions</th>\n                        </tr>\n                        </thead>\n                        <tbody>\n                        {logs.map((logs) => (\n                            <tr key={logs.user_id}>\n                                <td>{logs.user_id}</td>\n                                 <td>{logs.username}</td>\n\n                                <td><button type=\"button\" onClick={(e) => handleDelete(e, logs.user_id)}>Delete {logs.user_id}</button></td>\n                            </tr>\n                        ))}\n                        </tbody>\n                    </table>\n                </div>\n            </div> }\n        </div>\n    );\n}\n\nexport default DeleteAdmin;","/Users/josh/Documents/GitHub/ims/src/Admin.js",[],[],"/Users/josh/Documents/GitHub/ims/src/SubmissionPage.js",["135","136"],[],"import Logo from \"./images/SpecialRecLogo.png\";\nimport \"./css/admin.css\"\nimport background from \"./images/bg-01.jpg\";\nimport Employee from \"./Employee\";\nimport {Link} from \"react-router-dom\";\n\n\nconst SubmissionPage = () => {\n\n\n\n\n    return (\n\n        <div className=\"limiter\">\n            <div className=\"container-login100\" style={{backgroundImage: `url(${background})`}}>\n                <div className=\"wrap-login100\">\n                    <div className=\"login100-form validate-form\">\n              <span className=\"login100-form-logo\">\n                <img src={Logo} width={120} height={120}/>\n              </span>\n                        <span className=\"login100-form-title p-b-34 p-t-27\">\n                <div className=\"greenUnderline\">Form Submitted</div>\n              </span>\n                        <div className=\"container-login100-form-btn\">\n                            <Link to=\"/\">\n                            <button className=\"custombutton\">\n                                Home Page\n                            </button>\n                                </Link>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    );\n}\n\nexport default SubmissionPage;","/Users/josh/Documents/GitHub/ims/src/PrivateRoute.js",["137"],[],"import React from \"react\";\nimport { Navigate, Route } from \"react-router-dom\";\n\nfunction PrivateRoute({ children }) {\n    const isAuthenticated = localStorage.getItem(\"isAuthenticated\");\n\n    return (\n        isAuthenticated ? children : <Navigate to=\"/\" />\n    );\n}\n\nexport default PrivateRoute;\n","/Users/josh/Documents/GitHub/ims/src/forms/MinorInjuryLog.js",["138"],[],"import \"../css/MinorInjuryLogCSS.css\"\nimport \"../images/icons/FVSRA_ICON.png\"\nimport logo from \".//PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport {useState} from \"react\";\nimport {useNavigate} from \"react-router-dom\";\n\n\nconst MinorInjury = () => {\nconst [date, setDate] = useState('');\nconst [time, setTime] = useState('');\nconst [injury, setInjury] = useState('');\nconst [injuryLocation, setInjuryLocation] = useState('');\nconst [treatment, setTreatment] = useState('');\nconst [injuryOccur, setInjuryOccur] = useState('');\nconst [facility, setFacility] = useState('');\nconst [staffName, setStaffName] = useState('');\nconst navigate = useNavigate() //Like going back and forward in \"history\"/back from the previous or next page\n\n\n  const handleSubmit = (e) => { //Handles the onSubmit action of the log\n    e.preventDefault();\n\n    let minorInjuryLogObj = {\n      \"injury_date\": date,\n      \"injury_time\": time,\n      \"name_of_injured\": injury,\n      \"injury_location\": injuryLocation,\n      \"treatment\": treatment,\n      \"how_injury_occurred\": injuryOccur,\n      \"facility_where_injury_occurred\": facility,\n      \"full_name_of_staff\": staffName\n    }\n\n    fetch('https://api.foxvalleyspecialrec.com/fvsra/minorInjuryLog', {\n      method: 'POST',\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(minorInjuryLogObj)\n    }).then(() => {\n\n      navigate(\"/submitted\") //Redirects page\n\n    })\n\n  }\n\n  return (\n<div>\n        <img className=\"MLF_FVSRA\" src={logo} />\n  <form onSubmit={handleSubmit}>\n        <table className=\"MLF_shift-down\">\n          <colgroup><col width={120} />\n            <col width={110} />\n            <col width={220} />\n            <col width={130} />\n            <col width={150} />\n            <col width={350} />\n            <col width={200} />\n            <col width={140} /> \n          </colgroup>\n\n          <thead>\n            <tr>\n              <th>Date</th>\n              <th>Time</th>\n              <th>Name of Injury</th>\n              <th>Injury Location</th>\n              <th>Treatment</th>\n              <th>How injury occurred</th>\n              <th>Facility/Location where injury occurred</th>\n              <th>Full Name of staff who notified guardian</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr>\n              <td><input type=\"date\" name=\"date\" value={date} onChange={(e) => setDate(e.target.value)} id=\"date\" /></td>\n              <td><input type=\"time\" name=\"time\" value={time} onChange={(e) => setTime(e.target.value)} id=\"time\" /></td>\n              <td><input type=\"text\" placeholder=\"i.e Incision\" name=\"injury\" value={injury} onChange={(e) => setInjury(e.target.value)} id=\"injury\"  required /></td>\n              <td><input type=\"text\" placeholder=\"i.e Right Leg\" name=\"injury-location\" value={injuryLocation} onChange={(e) => setInjuryLocation(e.target.value)} id=\"injury-location\" required /></td>\n              <td><input type=\"text\" placeholder=\"i.e Bandage\" name=\"treatment\" value={treatment} onChange={(e) => setTreatment(e.target.value)} id=\"treatment\" required /></td>\n              <td><input type=\"text\" placeholder=\"i.e Slipped on wet floor\" name=\"injury-occur\" value={injuryOccur} onChange={(e) => setInjuryOccur(e.target.value)} id=\"injury-occur\" required /></td>\n              <td><input type=\"text\" placeholder=\"i.e Food Court\" name=\"facility\" value={facility} onChange={(e) => setFacility(e.target.value)} id=\"facility\" required /></td>\n              <td><input type=\"text\" placeholder=\"John Doe\" name=\"staff-name\" id=\"staff-name\" value={staffName} onChange={(e) => setStaffName(e.target.value)} required /></td>\n            </tr>\n          </tbody>\n        </table>\n      \n          <footer className=\"MLF_bottom\">\n          <button className=\"MLF_submit\">Submit</button>\n        </footer>\n  </form>\n        </div>\n    );\n}\n \nexport default MinorInjury;","/Users/josh/Documents/GitHub/ims/src/forms/NotificationOfInjuryReport.js",["139","140"],[],"import \"../css/NotificationOfInjurytoEmployerReport_CSS.css\"\nimport \"../images/icons/FVSRA_ICON.png\"\nimport logo from \".//PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport {useState} from \"react\";\nimport {useNavigate} from \"react-router-dom\";\n\n\nconst NotificationReport = () => {\n\n  const [name, setName] = useState('');\n  const [date, setDate] = useState('');\n  const [time, setTime] = useState('');\n  const [specificLocation, setSpecificLocation] = useState('');\n  const [reporting, setReporting] = useState('No');\n  const [dateReported, setDateReported] = useState('');\n  const [timeReported, setTimeReported] = useState('');\n  const [reportedTo, setReportedTo] = useState('');\n  const [describeInjury, setDescribeInjury] = useState('');\n  const [peoplePresent, setPeoplePresent] = useState('');\n  const [partsInjured, setPartsInjured] = useState('');\n  const [medicalAttention, setMedicalAttention] = useState('No');\n  const [treatment, setTreatment] = useState('');\n  const [injuredPreviously, setInjuredPreviously] = useState('No');\n  const [describeInjuredPrior, setDescribeInjuredPrior] = useState('');\n  const [locationTreatment, setLocationTreatment] = useState('');\n  const [signature, setSignature] = useState('');\n  const [dateSignature, setDateSignature] = useState('');\n  const navigate = useNavigate() //Like going back and forward in \"history\"/back from the previous or next page\n\n  const handleSubmit = (e) => { //Handles the onSubmit action of the log\n    e.preventDefault();\n\n    let NotificationReportObj = {\n      \"Employee_Name\": name,\n      \"Date_of_Incident\": date,\n      \"Time_of_Incident\": time,\n      \"Specific_location_of_accident\": specificLocation,\n      \"Are_you_reporting_the_injury_for_the_first_time_using_this_form\": reporting,\n      \"Reporting_Date\": dateReported,\n      \"Reporting_Time\": timeReported,\n      \"Reported_To\": reportedTo,\n      \"Describe_how_the_injury_occurred\": describeInjury,\n      \"Name_all_people_present_at_the_time_of_injury\": peoplePresent,\n      \"Identify_all_body_parts_you_injured\": partsInjured,\n      \"Did_you_seek_medical_attention_on_the_date_of_the_accident\": medicalAttention,\n      \"If_yes_where_did_you_seek_treatment\":treatment,\n      \"Have_you_injured_this_body_part_previously\":injuredPreviously,\n      \"If_yes_describe_which_body_part_and_what_the_prior_injury_was\":describeInjuredPrior,\n      \"If_yes_where_did_you_receive_treatment\":locationTreatment,\n      \"Employee_Signature\":signature,\n      \"Signature_Date\":dateSignature\n    }\n\n    fetch('https://api.foxvalleyspecialrec.com/fvsra/notificationOfInjuryToEmployerReport', {\n      method: 'POST',\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(NotificationReportObj)\n    }).then(() => {\n      navigate(\"/submitted\") //Redirects page\n    })\n\n  }\n\n    return ( \n        <div>\n          <form onSubmit={handleSubmit}>\n          <div className=\"NIRF_entire-page\">\n          <div className=\"NIRF_top-space\" />\n          <div className=\"NIRF_page-head\">\n            <div className=\"NIRF_page-head-grid\">\n              <div>\n                <p style={{textIndent: '0pt', textAlign: 'left'}}><span><img alt=\"image\" height={68} src={logo} width={222} /></span>\n                </p>\n              </div>\n              <div>\n                <table style={{borderCollapse: 'collapse'}} cellSpacing={0}>\n                  <tbody><tr style={{height: '16pt'}}>\n                      <td style={{width: '315pt', borderRightStyle: 'solid', borderRightWidth: '1pt', borderRightColor: 'white'}} rowSpan={3} bgcolor=\"#25408F\"><p className=\"NIRF_head-text4\" style={{paddingTop: '1pt', paddingLeft: '1pt', paddingRight: '4pt', textIndent: '0pt', textAlign: 'center'}}>\n                        </p><h2 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>Notification of Injury</h2>\n                        <h2 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>to Employer Report</h2>\n                        <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>\n                          (Employee to complete and submit to supervisor or HR.)\n                        </p>\n                      </td>\n                      <td style={{width: '57pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderRightStyle: 'solid', borderRightWidth: '1pt'}} bgcolor=\"#25408F\"><p className=\"NIRF_head-text2\" style={{paddingLeft: '7pt', paddingRight: '7pt', textIndent: '0pt', lineHeight: '15pt', textAlign: 'center'}}>\n                        </p><h3 style={{paddingTop: '2pt', paddingLeft: '8pt', textIndent: '0pt', textAlign: 'left'}}>Form</h3>\n                        <h2 style={{paddingTop: '3pt', paddingLeft: '7pt', textIndent: '0pt', textAlign: 'left'}}>04E</h2>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </div>\n          <div className=\"NIRF_header-body-space\" />\n          <table className=\"NIRF_form-table\">\n            <tbody><tr style={{height: '21pt'}}>\n                <td className=\"NIRF_blue-boxes-top\">\n                  1\n                </td>\n                <td colSpan={3} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Employee name</p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Employee_Name\"  value={name} onChange={(e) => setName(e.target.value)}  name=\"Employee_Name\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  2\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Date of incident (mm/dd/yyyy)</p>\n                  <input className=\"NIRF_Input2\"  type=\"date\" id=\"Date_of_Incident\"  value={date} onChange={(e) => setDate(e.target.value)}  name=\"Date_of_Incident\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" />\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Time of incident (hh/mm,\n                    a.m./p.m.)</p>\n                  <input className=\"NIRF_Input2\"  type=\"time\" id=\"Time_of_Incident\"  value={time} onChange={(e) => setTime(e.target.value)}  name=\"Time_of_Incident\" />\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"NIRF_blue-boxes-top\">\n                  3\n                </td>\n                <td colSpan={3} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Specific location of accident. (Ex. Second floor hallway of recreation center, storage closet of maintenance shed, south entrance of aquatic facility, etc.)</p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Employee_Name\"  value={specificLocation} onChange={(e) => setSpecificLocation(e.target.value)}  name=\"Employee_Name\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  4\n                </td>\n                <td colSpan={2} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Are you reporting the injury for the first time using this form?</p>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"NIRF_inputGrid\">\n                    <div className=\"NIRF_inputGrid\">\n                      <div className=\"NIRF_s3-right\">Yes</div>\n                      <div className=\"NIRF_centerInput\">\n                        <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"Yes\" id=\"reportingYes\"  value={\"Yes\"} onClick={() => setReporting(\"Yes\")}  name=\"ReportInjuryForFirstTime\" />\n                      </div>\n                    </div>\n                    <div className=\"NIRF_inputGrid\">\n                      <div className=\"NIRF_s3-right\">No</div>\n                      <div className=\"NIRF_centerInput\">\n                        <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"No\" id=\"reportingNo\"  value={\"No\"} onClick={() => setReporting(\"No\")}  name=\"ReportInjuryForFirstTime\" defaultChecked />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'none', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'none', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>\n                    If no, when did you first report the injury (verbally or in writing) and to whom did you report it?\n                  </p>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Date</p>\n                  <input className=\"NIRF_Input2\"  type=\"date\" id=\"Date_of_Incident\"  value={dateReported} onChange={(e) => setDateReported(e.target.value)}  name=\"Date_of_Incident\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" />\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'none', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Time</p>\n                  <input className=\"NIRF_Input2\"  type=\"time\" id=\"Time_of_Incident\"  value={timeReported} onChange={(e) => setTimeReported(e.target.value)}  name=\"Time_of_Incident\" />\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Reported to</p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Reported_to\"  value={reportedTo} onChange={(e) => setReportedTo(e.target.value)}  name=\"Reported_to\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  5\n                </td>\n                <td colSpan={3} style={{borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Describe how the injury occurred. (Identify the job task you were doing and include a step-by-step explanation of what led to the injury.)\n                  </p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"describeInjury\"  value={describeInjury} onChange={(e) => setDescribeInjury(e.target.value)}  name=\"describeInjury\" required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  6\n                </td>\n                <td colSpan={3} style={{borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Name all people present at the time of injury (e.g., coworkers and/or witnesses)\n                  </p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"peoplePresent\"  value={peoplePresent} onChange={(e) => setPeoplePresent(e.target.value)}  name=\"peoplePresent\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  7\n                </td>\n                <td colSpan={3} style={{borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Identify all body parts you injured. (Be specific. Indicate left or right, upper or lower.)\n                  </p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"partInjured\"  value={partsInjured} onChange={(e) => setPartsInjured(e.target.value)}  name=\"partInjured\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"NIRF_blue-boxes\">\n                  8\n                </td>\n                <td colSpan={2} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Did you seek medical attention on the date of the accident?</p>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"NIRF_inputGrid\">\n                    <div className=\"NIRF_inputGrid\">\n                      <div className=\"NIRF_s3-right\">Yes</div>\n                      <div className=\"NIRF_centerInput\">\n                        <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"Yes\" id=\"SeekMedAttentionYes\"  value={\"Yes\"} onClick={() => setMedicalAttention(\"Yes\")}  name=\"SeekMedAttention\" />\n                      </div>\n                    </div>\n                    <div className=\"NIRF_inputGrid\">\n                      <div className=\"NIRF_s3-right\">No</div>\n                      <div className=\"NIRF_centerInput\">\n                        <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"No\" id=\"SeekMedAttentionNo\"  value={\"No\"} onClick={() => setMedicalAttention(\"No\")}  name=\"SeekMedAttention\" defaultChecked />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>If yes, where did you seek treatment?</p>\n                  <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Reported_to\"  value={treatment} onChange={(e) => setTreatment(e.target.value)}  name=\"Reported_to\" /></div>\n                </td>\n              </tr>\n            </tbody></table>\n          <div className=\"NIRF_bottom-space\" />\n        </div>\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        {/*PAGE BREAK*/}\n        <div className=\"NIRF_entire-page\">\n          <div className=\"NIRF_top-space\" />\n          <div className=\"NIRF_page-head\">\n            <div className=\"NIRF_page-head-grid\">\n              <div>\n                <p style={{textIndent: '0pt', textAlign: 'left'}}><span><img alt=\"image\" height={68} src={logo} width={222} /></span>\n                </p>\n              </div>\n              <div>\n                <table style={{borderCollapse: 'collapse'}} cellSpacing={0}>\n                  <tbody><tr style={{height: '16pt'}}>\n                      <td style={{width: '315pt', borderRightStyle: 'solid', borderRightWidth: '1pt', borderRightColor: 'white'}} rowSpan={3} bgcolor=\"#25408F\"><p className=\"NIRF_head-text4\" style={{paddingTop: '1pt', paddingLeft: '1pt', paddingRight: '4pt', textIndent: '0pt', textAlign: 'center'}}>\n                        </p><h2 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>Notification of Injury</h2>\n                        <h2 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>to Employer Report</h2>\n                        <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>\n                          (Employee to complete and submit to supervisor or HR.)\n                        </p>\n                      </td>\n                      <td style={{width: '57pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderRightStyle: 'solid', borderRightWidth: '1pt'}} bgcolor=\"#25408F\"><p className=\"NIRF_head-text2\" style={{paddingLeft: '7pt', paddingRight: '7pt', textIndent: '0pt', lineHeight: '15pt', textAlign: 'center'}}>\n                        </p><h3 style={{paddingTop: '2pt', paddingLeft: '8pt', textIndent: '0pt', textAlign: 'left'}}>Form</h3>\n                        <h2 style={{paddingTop: '3pt', paddingLeft: '7pt', textIndent: '0pt', textAlign: 'left'}}>04E</h2>\n                        <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>(pg. 2)</p>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </div>\n          <div className=\"NIRF_header-body-space\" />\n\n            <table className=\"NIRF_form-table\">\n              <tbody><tr style={{height: '22pt'}}>\n                  <td className=\"NIRF_blue-boxes\">\n                    9\n                  </td>\n                  <td colSpan={2} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E'}}>\n                    <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Have you injured this body part previously?</p>\n                  </td>\n                  <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                    <div className=\"NIRF_inputGrid\">\n                      <div className=\"NIRF_inputGrid\">\n                        <div className=\"NIRF_s3-right\">Yes</div>\n                        <div className=\"NIRF_centerInput\">\n                          <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"Yes\" id=\"DamagePreviousYes\"  value={\"Yes\"} onClick={() => setInjuredPreviously(\"Yes\")}  name=\"DamagePrevious\" />\n                        </div>\n                      </div>\n                      <div className=\"NIRF_inputGrid\">\n                        <div className=\"NIRF_s3-right\">No</div>\n                        <div className=\"NIRF_centerInput\">\n                          <input className=\"NIRF_Input\"  type=\"radio\" defaultValue=\"No\" id=\"DamagePreviousNo\"  value={\"No\"} onClick={() => setInjuredPreviously(\"No\")}  name=\"DamagePrevious\" defaultChecked />\n                        </div>\n                      </div>\n                    </div>\n                  </td>\n                </tr>\n                <tr style={{height: '27pt'}}>\n                  <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                  <td colSpan={3} style={{width: '202pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                    <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>If yes, please describe which body part and what the prior injury was.</p>\n                    <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Injured_Prior\"  value={describeInjuredPrior} onChange={(e) => setDescribeInjuredPrior(e.target.value)}  name=\"Injured_Prior\" /></div>\n                  </td>\n                </tr>\n                <tr style={{height: '21pt'}}>\n                  <td className=\"NIRF_blue-boxes-top\" />\n                  <td colSpan={3} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                    <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>If yes, where did you receive treatment?</p>\n                    <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"locationTreatment\"  value={locationTreatment} onChange={(e) => setLocationTreatment(e.target.value)}  name=\"LocationTreatment\" /></div>\n                  </td>\n                </tr>\n                <tr style={{height: '25pt'}}>\n                  <td className=\"NIRF_blue-boxes\" />\n                  <td colSpan={3} style={{width: '526pt', borderTopStyle: 'none', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'none', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>\n                      The above information is true and accurate:\n                    </p>\n                  </td>\n                </tr>\n                <tr style={{height: '27pt'}}>\n                  <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                  <td colSpan={2} style={{width: '283pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'none', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                    <p className=\"NIRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>(Employee Signature)</p>\n                    <div className=\"NIRF_endInput\"><input className=\"NIRF_Input\"  type=\"text\" id=\"Employee_Signature\"  value={signature} onChange={(e) => setSignature(e.target.value)}  name=\"Employee_Signature\" /></div>\n                  </td>\n                  <td style={{width: '202pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'none', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                    <p className=\"NIRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Date</p>\n                    <input className=\"NIRF_Input2\"  type=\"date\" id=\"Signature_Date\"  value={dateSignature} onChange={(e) => setDateSignature(e.target.value)}  name=\"Signature_Date\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" />\n                  </td>\n                </tr>\n                <tr style={{height: '25pt'}}>\n                  <td className=\"NIRF_blue-boxes\" />\n                  <td colSpan={3} style={{width: '526pt', borderTopStyle: 'none', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}} />\n                </tr>\n              </tbody></table>\n            <div className=\"NIRF_center-text\">\n              <button name=\"submit4E\" >Submit</button>\n            </div>\n\n          <div className=\"NIRF_bottom-space\" />\n        </div>\n      </form>\n      </div>\n     );\n}\n \nexport default NotificationReport;","/Users/josh/Documents/GitHub/ims/src/forms/AccidentIncidentReport.js",["141","142"],[],"import \"../css/AccidentIncidentReport_CSS.css\"\nimport \"../images/icons/FVSRA_ICON.png\"\nimport logo from \".//PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport {useState} from \"react\";\nimport {useNavigate} from \"react-router-dom\";\n\nconst AccidentReport = () => {\n  const [AgencyName, setAgencyName] = useState('Fox Valley Special Recreation Association');\n  const [TodaysDate, setTodaysDate] = useState('');\n  const [IncidentDate, setIncidentDate] = useState('');\n  const [IncidentTime, setIncidentTime] = useState('');\n  const [PersonCompletingFormName, setPersonCompletingFormName] = useState('');\n  const [PersonCompletingFormTitle, setPersonCompletingFormTitle] = useState('');\n  const [BusinessPhone, setBusinessPhone] = useState('');\n  const [BusinessEmail, setBusinessEmail] = useState('');\n  const [HowIncidentOccurred, setHowIncidentOccurred] = useState('');\n  const [LocationName, setLocationName] = useState('');\n  const [DoesLocationHaveAddress, setDoesLocationHaveAddress] = useState('');\n  const [StreetAddress, setStreetAddress] = useState('');\n  const [City, setCity] = useState('');\n  const [State, setState] = useState('');\n  const [ZipCode, setZipCode] = useState('');\n  const [Location, setLocation] = useState('');\n  const [PrimaryLocation, setPrimaryLocation] = useState('');\n  const [InjuredPerson, setInjuredPerson] = useState('');\n  const [EmpLName, setEmpLName] = useState('');\n  const [EmpFName, setEmpFName] = useState('');\n  const [EmpAddress, setEmpAddress] = useState('');\n  const [EmpCity, setEmpCity] = useState('');\n  const [EmpState, setEmpState] = useState('');\n  const [EmpZip, setEmpZip] = useState('');\n  const [EmpHomePhone, setEmpHomePhone] = useState('');\n  const [EmpWorkPhone, setEmpWorkPhone] = useState('');\n  const [EmpCellPhone, setEmpCellPhone] = useState('');\n  const [EmpAge, setEmpAge] = useState('');\n  const [EmpSex, setEmpSex] = useState('');\n  const [IsInjuredPersonAgencyVolunteer, setIsInjuredPersonAgencyVolunteer] = useState('');\n  const [InjuryDescription, setInjuryDescription] = useState('');\n  const [InjuredStatements, setInjuredStatements] = useState('');\n  const [InjuredSaid, setInjuredSaid] = useState('');\n  const [FirstAid, setFirstAid] = useState('');\n  const [PersonAndPositionOfFirstAidGiver, setPersonAndPositionOfFirstAidGiver] = useState('');\n  const [FirstAidGiven, setFirstAidGiven] = useState('');\n  const [CprOrAed, setCprOrAed] = useState('');\n  const [ParamedicsOffered, setParamedicsOffered] = useState('');\n  const [WerePoliceCalled, setWerePoliceCalled] = useState(\"\");\n  const [PoliceDepName, setPoliceDepName] = useState('');\n  const [OfficerName, setOfficerName] = useState('');\n  const [DidYouExpectAClaim, setDidYouExpectAClaim] = useState('');\n  const [WasPropDamaged, setWasPropDamaged] = useState('');\n  const [HowWasPersonInvolved, setHowWasPersonInvolved] = useState('');\n  const [PropDamageLName, setPropDamageLName] = useState('');\n  const [PropDamageFName, setPropDamageFName] = useState('');\n  const [PropDamAddress, setPropDamAddress] = useState('');\n  const [PropDamCity, setPropDamCity] = useState('');\n  const [PropDamState, setPropDamState] = useState('');\n  const [PropDamZip, setPropDamZip] = useState('');\n  const [PropDamPhone, setPropDamPhone] = useState(\"\");\n  const [PropDamDescription, setPropDamDescription] = useState('');\n  const [WitnessLName, setWitnessLName] = useState('');\n  const [WitnessFName, setWitnessFName] = useState('');\n  const [WitnessAddress, setWitnessAddress] = useState('');\n  const [WitnessCity, setWitnessCity] = useState('');\n  const [WitnessState, setWitnessState] = useState('');\n  const [WitnessZip, setWitnessZip] = useState('');\n  const [WitnessPhoneNum, setWitnessPhoneNum] = useState('');\n  const [WitnessStatement, setWitnessStatement] = useState('');\n  const [WitnessSaid, setWitnessSaid] = useState('');\n  const [WitnessLocationDuringIncident, setWitnessLocationDuringIncident] = useState('');\n  const navigate = useNavigate() //Like going back and forward in \"history\"/back from the previous or next page\n\n\n  const handleSubmit = (e) => {\n    e.preventDefault();\n\n    let accidentReportObj = {\n      \"Agency_Name\" : AgencyName,\n      \"Todays_Date\" : TodaysDate,\n      \"Date_of_Incident\" : IncidentDate,\n      \"Time_of_incident\" : IncidentTime,\n      \"Name_of_the_person_Completing_the_report\" : PersonCompletingFormName,\n      \"Title_Of_Person_Completing_the_report\" : PersonCompletingFormTitle,\n      \"Business_Phone\" : BusinessPhone,\n      \"Business_Email\" : BusinessEmail,\n      \"How_did_the_incident_Occur\" : HowIncidentOccurred,\n      \"Name_of_the_location\" : LocationName,\n      \"Is_there_an_address_for_incident_Location\" : DoesLocationHaveAddress,\n      \"Street_Address\" : StreetAddress,\n      \"City\" : City,\n      \"State\" : State,\n      \"Zip_code\" : ZipCode,\n      \"Location\" : Location,\n      \"Primary_Location\" : PrimaryLocation,\n      \"Was_a_person_injured\" : InjuredPerson,\n      \"Last_name_employee_injury\" : EmpLName,\n      \"First_name_employee_injury\" : EmpFName,\n      \"Address_employee_injury\" : EmpAddress,\n      \"city_employee_injury\" : EmpCity,\n      \"State_employee_injury\" : EmpState,\n      \"Zip_code_employee_injury\" : EmpZip,\n      \"Home_phone_Number\" : EmpHomePhone,\n      \"Work_phone_number\" : EmpWorkPhone,\n      \"Cell_phone_number\" : EmpCellPhone,\n      \"Age\" : EmpAge,\n      \"Sex\" : EmpSex,\n      \"Is_injured_person_an_agency_volunteer\" : IsInjuredPersonAgencyVolunteer,\n      \"Describe_the_injury\" : InjuryDescription,\n      \"Did_injured_person_make_any_statements\" : InjuredStatements,\n      \"If_yes_what_did_injured_person_say\" : InjuredSaid,\n      \"was_first_aid_administered\" : FirstAid,\n      \"Name_and_position_of_person_who_administered_the_First_aid\" : PersonAndPositionOfFirstAidGiver,\n      \"What_first_aid_was_given\" : FirstAidGiven,\n      \"Did_first_aid_involve_AED_and_or_CPR\" : CprOrAed,\n      \"Were_paramedic_services_offered\" : ParamedicsOffered,\n      \"Were_Police_Called\": WerePoliceCalled,\n      \"Name_of_the_police_department\" : PoliceDepName,\n      \"Name_of_the_officer\" : OfficerName,\n      \"did_you_expect_this_person_submit_a_claim\" : DidYouExpectAClaim,\n      \"Was_Property_Damaged_As_A_Result_Of_This_AccidentOrIncident\" : WasPropDamaged,\n      \"If_Yes_How_Was_The_Person_Involved_In_The_AccidentOrIncident\" : HowWasPersonInvolved,\n      \"last_name_Property_damage\" : PropDamageLName,\n      \"first_name_Property_damage\" : PropDamageFName,\n      \"Address_Property_damage\" : PropDamAddress,\n      \"city_Property_damage\" : PropDamCity,\n      \"state_Property_damage\" : PropDamState,\n      \"zip_code_Property_damage\" : PropDamZip,\n      \"phone_num_Property_Damage\": PropDamPhone,\n      \"Describe_the_property_damage\" : PropDamDescription,\n      \"Last_name_witness_information\" : WitnessLName,\n      \"first_name_witness_information\" : WitnessFName,\n      \"Address_witness_information\" : WitnessAddress,\n      \"City_witness_information\" : WitnessCity,\n      \"State_witness_information\" : WitnessState,\n      \"zip_code_witness_information\" : WitnessZip,\n      \"phone_number_witness_information\" : WitnessPhoneNum,\n      \"did_Witness_make_any_statements\" : WitnessStatement,\n      \"If_yes_what_did_witness_say\" : WitnessSaid,\n      \"Where_was_witness_when_the_accident\" : WitnessLocationDuringIncident\n    }\n\n    fetch('https://api.foxvalleyspecialrec.com/fvsra/accidentIncidentReport', {\n      method: 'POST',\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(accidentReportObj)\n    }).then(() => {\n\n      navigate(\"/submitted\") //Redirects page\n    })\n\n  }\n\n\n\nreturn (\n        <div>\n          <form onSubmit={handleSubmit}>\n        <div className=\"ARF_entire-page\">\n          <div className=\"ARF_top-space\" />\n          <div className=\"ARF_page-head\">\n            <div className=\"ARF_page-head-grid\">\n              <div>\n                <p style={{textIndent: '0pt', textAlign: 'left'}}><span><img alt=\"image\" height={68} src={logo} width={222} /></span>\n                </p>\n              </div>\n              <div>\n                <table style={{borderCollapse: 'collapse'}} cellSpacing={0}>\n                  <tbody><tr style={{height: '16pt'}}>\n                      <td style={{width: '315pt', borderRightStyle: 'solid', borderRightWidth: '1pt', borderRightColor: 'white'}} rowSpan={3} bgcolor=\"#25408F\"><p className=\"ARF_head-text4\" style={{paddingTop: '1pt', paddingLeft: '1pt', paddingRight: '4pt', textIndent: '0pt', textAlign: 'center'}}>\n                        </p><h1 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>Accident/Incident Report</h1>\n                        <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>\n                          Attorney/Client Privileged Document\n                        </p>\n                      </td>\n                      <td style={{width: '57pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderRightStyle: 'solid', borderRightWidth: '1pt'}} bgcolor=\"#25408F\"><p className=\"ARF_head-text2\" style={{paddingLeft: '7pt', paddingRight: '7pt', textIndent: '0pt', lineHeight: '15pt', textAlign: 'center'}}>\n                        </p><h3 style={{paddingTop: '2pt', paddingLeft: '8pt', textIndent: '0pt', textAlign: 'left'}}>Form</h3>\n                        <h2 style={{paddingTop: '3pt', paddingLeft: '14pt', textIndent: '0pt', textAlign: 'left'}}>01</h2>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"ARF_header-body-space\" />\n\n          <table className=\"ARF_form-table\">\n            <tbody><tr style={{height: '21pt'}}>\n                <td className=\"ARF_blue-boxes-top\">\n                  1\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Agency name</p>\n                  <input className=\"ARF_Input\" type=\"text\" name=\"AgencyName\" value={AgencyName} onChange={(e) => setAgencyName(e.target.value)} id=\"AgencyName\" required/>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Today’s date</p>\n                  <input className=\"ARF_Input\" type=\"date\" name=\"TodaysDate\" value={TodaysDate} onChange={(e) => setTodaysDate(e.target.value)} id=\"TodaysDate\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" required/>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  2\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Date of incident (mm/dd/yyyy)</p>\n                  <input className=\"ARF_Input\" type=\"date\" name=\"incidentDate\" value={IncidentDate} onChange={(e) => setIncidentDate(e.target.value)} id=\"IncidentDate\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" required />\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Time of incident (hh/mm,\n                    a.m./p.m.)</p>\n                  <input className=\"ARF_Input\" type=\"time\" name=\"incidentTime\" value={IncidentTime} onChange={(e) => setIncidentTime(e.target.value)} id=\"IncidentTime\" required />\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  3\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Name of person completing the report</p>\n                  <input className=\"ARF_Input\" type=\"text\" value={PersonCompletingFormName} onChange={(e) => setPersonCompletingFormName(e.target.value)} id=\"Name_of_person_completing_the_report\" name=\"Name_of_person_completing_the_report\" />\n                </td><td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Title of person completing report</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PersonCompletingFormTitle\" value={PersonCompletingFormTitle} onChange={(e) => setPersonCompletingFormTitle(e.target.value)} id=\"PersonCompletingFormName\" required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '21pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  4\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Business phone</p>\n                  <input className=\"ARF_Input\" type=\"tel\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" name=\"BusinessPhone\" value={BusinessPhone} onChange={(e) => setBusinessPhone(e.target.value)} id=\"BusinessPhone\" required />\n                </td><td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Business email</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"email\" name=\"BusinessEmail\" id=\"BusinessEmail\" value={BusinessEmail} onChange={(e) => setBusinessEmail(e.target.value)} required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  5\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>How did the incident\n                    occur? (Provide a brief, factual description; do not speculate on fault, etc.)</p>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" placeholder=\"i.e. Car Wreck\" name=\"HowIncidentOccurred\" value={HowIncidentOccurred} onChange={(e) => setHowIncidentOccurred(e.target.value)} id=\"HowIncidentOccurred\" required/></div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"ARF_Input\" type=\"text\" id=\"HowDidIncidentOccur2\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '4pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"ARF_Input\" type=\"text\" id=\"HowDidIncidentOccur3\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  6\n                </td>\n                <td colSpan={3} style={{borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Name of the location (park, pool,\n                    community center; <span className=\"ARF_s7\">Ex. Smith Pool, Johnson Community Center</span>) or nearest intersection\n                  </p>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>where the incident occurred.</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" placeholder=\"i.e. Washington\" name=\"LocationName\" value={LocationName} onChange={(e) => setLocationName(e.target.value)} id=\"LocationName\" required/></div>\n                </td>\n              </tr>\n              <tr style={{height: '19pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  7\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>\n                    Is there an address for incident location? If yes, please provide the following:</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"DoesLocationHaveAddress\" value={\"Yes\"} onClick={() => setDoesLocationHaveAddress(\"Yes\")} id=\"DoesLocationHaveAddress\"  required />\n                    </div>\n                  </div>\n                  {/*                <p class=\"s3\" style=\"text-indent: 0pt;line-height: 10pt;text-align: right;\">Yes <div class=\"centerInput\"><input className=\"ARF_Input\" type=\"checkbox\" id=\"horns\" name=\"horns\"></div></p>*/}\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"DoesLocationHaveAddress\" value={\"No\"} onClick={() => setDoesLocationHaveAddress(\"No\")} id=\"DoesLocationHaveAddress\"  required />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"DoesLocationHaveAddress\" value={\"Unknown\"} onClick={() => setDoesLocationHaveAddress(\"Unknown\")} id=\"DoesLocationHaveAddress\"  required />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Street address</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"StreetAddress\" value={StreetAddress} onChange={(e) => setStreetAddress(e.target.value)} id=\"StreetAddress\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>City</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"City\" value={City} onChange={(e) => setCity(e.target.value)} id=\"City\"/></div>\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>State</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" placeholder=\"i.e. Illinois\" name=\"State\" value={State} onChange={(e) => setState(e.target.value)} id=\"State\" /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Zip code</p>\n                  <input className=\"ARF_Input\" type=\"tel\" placeholder=\"00000\" name=\"ZipCode\" pattern=\"[0-9]{5}\" value={ZipCode} onChange={(e) => setZipCode(e.target.value)} id=\"ZipCode\"   />\n                </td>\n              </tr>\n              <tr style={{height: '5pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n              </tr>\n              <tr style={{height: '24pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  8\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingLeft: '1pt', textIndent: '0pt', textAlign: 'left'}}>Location (Specify the exact type of location/facility where injury occurred. Ex. maintenance garage, sports field, aquatic\n                    outdoor, golf course, etc.)</p>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"Location\" value={Location} onChange={(e) => setLocation(e.target.value)} id=\"Location\"  required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '6pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"ARF_Input\" type=\"text\" id=\"LocationSpecify2\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '24pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  9\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Primary location (Specify exact location. Ex. lap pool, cart storage, classroom, pavilion)</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PrimaryLocation\" value={PrimaryLocation} onChange={(e) => setPrimaryLocation(e.target.value)} id=\"PrimaryLocation\"  required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td colSpan={4} className=\"ARF_blue-boxes\" style={{borderRight: '3px solid #24418E'}}>\n                  <div className=\"ARF_text-left\">BODILY INJURY</div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td colSpan={4} className=\"ARF_white-boxes-red-text\" style={{borderRight: '3px solid #24418E', borderLeft: '1px solid #24418E'}}>\n                  <div className=\"ARF_text-left\">If an employee was injured, please submit the form for an Employee Injury (Form 04) type of incident.</div>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  10\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Was a person injured? (Ex. patron, citizen, participant, volunteer)</p></td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"InjuredPerson\" value={\"Yes\"} onClick={() => setInjuredPerson(\"Yes\")} id=\"InjuredPerson\"  required />\n                    </div>\n                  </div>\n                  {/*                <p class=\"s3\" style=\"text-indent: 0pt;line-height: 10pt;text-align: right;\">Yes <div class=\"centerInput\"><input className=\"ARF_Input\" type=\"checkbox\" id=\"horns\" name=\"horns\"></div></p>*/}\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"InjuredPerson\" value={\"No\"} onClick={() => setInjuredPerson(\"No\")} id=\"InjuredPerson\"  required />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"InjuredPerson\" value={\"Unknown\"} onChange={() => setInjuredPerson(\"Unknown\")} id=\"InjuredPerson\"  required />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  11\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingRight: '9pt', textIndent: '0pt', textAlign: 'left'}}>If yes, provide the following information:</p>\n                </td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Last name</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpLName\" value={EmpLName} onChange={(e) => setEmpLName(e.target.value)} id=\"EmpLName\"  /></div>\n                </td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'none', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>First name</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\"  name=\"EmpFName\" value={EmpFName} onChange={(e) => setEmpFName(e.target.value)} id=\"EmpFName\"  /></div>\n                </td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Address</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpAddress\" value={EmpAddress} onChange={(e) => setEmpAddress(e.target.value)} id=\"EmpAddress\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '29pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>City</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpCity\" value={EmpCity} onChange={(e) => setEmpCity(e.target.value)} id=\"EmpCity\"   /></div>\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>State</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpState\" value={EmpState} onChange={(e) => setEmpState(e.target.value)} id=\"EmpState\"  /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Zip code</p>\n                  <input className=\"ARF_Input\" type=\"tel\"  name=\"EmpZip\" value={EmpZip} onChange={(e) => setEmpZip(e.target.value)} id=\"EmpZip\" placeholder=\"00000\"  pattern=\"[0-9]{5}\" />\n                </td>\n              </tr>\n              <tr style={{height: '29pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Home phone #</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpHomePhone\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" value={EmpHomePhone} onChange={(e) => setEmpHomePhone(e.target.value)} id=\"EmpHomePhone\"  /></div>\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Work phone #</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" name=\"EmpWorkPhone\" value={EmpWorkPhone} onChange={(e) => setEmpWorkPhone(e.target.value)} id=\"EmpWorkPhone\"  /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Cell phone #</p>\n                  <input className=\"ARF_Input\" type=\"tel\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" name=\"EmpCellPhone\" value={EmpCellPhone} onChange={(e) => setEmpCellPhone(e.target.value)} id=\"EmpCellPhone\"   />\n                </td>\n              </tr>\n              <tr style={{height: '29pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={2} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Age</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"EmpAge\" value={EmpAge} onChange={(e) => setEmpAge(e.target.value)} id=\"EmpAge\"   /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid3\">\n                      <div className=\"ARF_s3\">Sex</div>\n                      <div className=\"ARF_s3-left\">Male</div>\n                      <div className=\"ARF_input-right\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Male\" name=\"EmpSex\" value={\"M\"} onClick={() => setEmpSex(\"M\")} id=\"EmpSex\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-left\">Female</div>\n                      <div className=\"ARF_input-right\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Female\" name=\"EmpSex\" value={\"F\"} onClick={() => setEmpSex(\"F\")} id=\"EmpSex\"  />\n\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  12\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Is the injured person an agency volunteer?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"IsInjuredPersonAgencyVolunteer\" value={\"Yes\"} onClick={() => setIsInjuredPersonAgencyVolunteer(\"Yes\")} id=\"IsInjuredPersonAgencyVolunteer\"   />\n\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"IsInjuredPersonAgencyVolunteer\" value={\"No\"} onChange={() => setIsInjuredPersonAgencyVolunteer(\"No\")} id=\"IsInjuredPersonAgencyVolunteer\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"IsInjuredPersonAgencyVolunteer\" value={\"Unknown\"} onChange={() => setIsInjuredPersonAgencyVolunteer(\"Unknown\")} id=\"IsInjuredPersonAgencyVolunteer\"  />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  13\n                </td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Describe the injury (affected body part and type of injury; Ex. contusion, bruise, laceration, sprain, break, etc.)</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"InjuryDescription\" value={InjuryDescription} onChange={(e) => setInjuryDescription(e.target.value)} id=\"InjuryDescription\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  14\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Did injured person make any statements?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"InjuredStatements\" value={\"Yes\"} onChange={() => setInjuredStatements(\"Yes\")} id=\"InjuredStatements\"   />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"InjuredStatements\" value={\"No\"} onChange={() => setInjuredStatements(\"No\")} id=\"InjuredStatements\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"InjuredStatements\" value={\"Unknown\"} onChange={() => setInjuredStatements(\"Unknown\")} id=\"InjuredStatements\"   />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"ARF_blue-boxes-bottom\">\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>If yes, what did injured person say?</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"InjuredSaid\" value={InjuredSaid} onChange={(e) => setInjuredSaid(e.target.value)} id=\"InjuredSaid\"   /></div>\n                </td>\n              </tr>\n            </tbody></table>\n          <div className=\"ARF_bottom-space\" />\n        </div>\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        {/*BREAK BETWEEN PAGES*/}\n        <div className=\"ARF_entire-page\">\n          <div className=\"ARF_top-space\" />\n          <div className=\"ARF_page-head\">\n            <div className=\"ARF_page-head-grid\">\n              <div>\n                <p style={{textIndent: '0pt', textAlign: 'left'}}><span><img alt=\"image\" height={68} src={logo} width={222} /></span>\n                </p>\n              </div>\n              <div>\n                <table style={{borderCollapse: 'collapse'}} cellSpacing={0}>\n                  <tbody><tr style={{height: '16pt'}}>\n                      <td style={{width: '315pt', borderRightStyle: 'solid', borderRightWidth: '1pt', borderRightColor: 'white'}} rowSpan={3} bgcolor=\"#25408F\"><p className=\"ARF_head-text4\" style={{paddingTop: '1pt', paddingLeft: '1pt', paddingRight: '4pt', textIndent: '0pt', textAlign: 'center'}}>\n                        </p><h1 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>Accident/Incident Report</h1>\n                        <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>\n                          Attorney/Client Privileged Document\n                        </p>\n                      </td>\n                      <td style={{width: '57pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderRightStyle: 'solid', borderRightWidth: '1pt'}} bgcolor=\"#25408F\"><p className=\"ARF_head-text2\" style={{paddingLeft: '7pt', paddingRight: '7pt', textIndent: '0pt', lineHeight: '15pt', textAlign: 'center'}}>\n                        </p><h3 style={{paddingTop: '2pt', paddingLeft: '8pt', textIndent: '0pt', textAlign: 'left'}}>Form</h3>\n                        <h2 style={{paddingTop: '3pt', paddingLeft: '14pt', textIndent: '0pt', textAlign: 'left'}}>01</h2>\n                        <div className=\"ARF_s5-center\">(pg. 2)</div>\n                      </td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </div>\n          <div className=\"ARF_header-body-space\" />\n          <table className=\"ARF_form-table\">\n            <tbody><tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  15\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Was first aid administered?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"FirstAid\" value={\"Yes\"} onChange={() => setFirstAid(\"Yes\")} id=\"FirstAid\"   />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"FirstAid\" value={\"No\"} onChange={() => setFirstAid(\"No\")} id=\"FirstAid\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"FirstAid\" value={\"Unknown\"} onChange={() => setFirstAid(\"Unknown\")} id=\"FirstAid\"   />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Name and position of person who administered first aid</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PersonAndPositionOfFirstAidGiver\" value={PersonAndPositionOfFirstAidGiver} onChange={(e) => setPersonAndPositionOfFirstAidGiver(e.target.value)} id=\"PersonAndPositionOfFirstAidGiver\"  /></div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>What first aid was given?</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"FirstAidGiven\" value={FirstAidGiven} onChange={(e) => setFirstAidGiven(e.target.value)} id=\"FirstAidGiven\"  /></div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Did first aid involve AED and/or CPR?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"CprOrAed\" value={\"Yes\"} onChange={() => setCprOrAed(\"Yes\")} id=\"CprOrAed\"  />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"CprOrAed\" value={\"No\"} onChange={() => setCprOrAed(\"No\")} id=\"CprOrAed\"  />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"CprOrAed\" value={\"Unknown\"} onChange={() => setCprOrAed(\"Unknown\")} id=\"CprOrAed\"  />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>If yes, please submit a PDRMA post-AED form.</p>\n                </td>\n              </tr>\n              <tr>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Were paramedic services offered?</p>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Called and refused (at scene by patron)\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"CalledAndRefused\" name=\"ParamedicsOffered\" value={\"CalledAndRefused\"} onClick={() => setParamedicsOffered(\"CalledAndRefused\")} id=\"ParamedicsOffered\"  />\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Offered and called\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"OfferedAndCalled\" name=\"ParamedicsOffered\" value={\"OfferedAndCalled\"} onClick={() => setParamedicsOffered(\"OfferedAndCalled\")} id=\"ParamedicsOffered\"   />\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Offered and refused\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"OfferedAndRefused\" name=\"ParamedicsOffered\" value={\"OfferedAndRefused\"} onClick={() => setParamedicsOffered(\"OfferedAndRefused\")} id=\"ParamedicsOffered\"   />\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Offered, refused, called by agency anyway\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"OfferedAndRefusedButCalledByAgency\" name=\"ParamedicsOffered\" value={\"OfferedAndRefusedButCalledByAgency\"} onClick={() => setParamedicsOffered(\"OfferedAndRefusedButCalledByAgency\")} id=\"ParamedicsOffered\"   />\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Unable to respond and called\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"UnableToRespond\" name=\"ParamedicsOffered\" value={\"UnableToRespond\"} onClick={() => setParamedicsOffered(\"UnableToRespond\")} id=\"ParamedicsOffered\"  />\n                    </div>\n                    <div />\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '19pt'}}>\n                <td className=\"ARF_blue-boxes\" />\n\n\n\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>\n                    Were police called?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" id=\"PoliceWereCalled\" onClick={() => setWerePoliceCalled(\"Yes\")} name=\"PoliceWereCalled\"  />\n                    </div>\n                  </div>\n\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">No</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" id=\"PoliceWereCalled\" onClick={() => setWerePoliceCalled(\"No\")} name=\"PoliceWereCalled\"  />\n                    </div>\n                  </div>\n\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_s3\">If yes, provide the following information:</div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Name of police department</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PoliceDepName\" value={PoliceDepName} onChange={(e) => setPoliceDepName(e.target.value)} id=\"PoliceDepName\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Name of officer</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"OfficerName\" value={OfficerName} onChange={(e) => setOfficerName(e.target.value)} id=\"OfficerName\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '19pt'}}>\n                <td className=\"ARF_blue-boxes\" />\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>\n                    Do you expect this person to submit a claim?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"DidYouExpectAClaim\" value={\"Yes\"} onClick={() => setDidYouExpectAClaim(\"Yes\")} id=\"DidYouExpectAClaim\"   />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"DidYouExpectAClaim\" value={\"No\"} onClick={() => setDidYouExpectAClaim(\"No\")} id=\"DidYouExpectAClaim\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"DidYouExpectAClaim\" value={\"Unknown\"} onClick={() => setDidYouExpectAClaim(\"Unknown\")} id=\"DidYouExpectAClaim\"   />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td colSpan={4} className=\"ARF_blue-boxes\" style={{borderRight: '3px solid #24418E'}}>\n                  <div className=\"ARF_text-left\">PROPERTY DAMAGE</div>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  16\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Was property damaged as a result of this accident/incident?</p></td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"WasPropDamaged\" value={\"Yes\"} onClick={() => setWasPropDamaged(\"Yes\")} id=\"WasPropDamaged\"  required />\n                    </div>\n                  </div>\n                  {/*                <p class=\"s3\" style=\"text-indent: 0pt;line-height: 10pt;text-align: right;\">Yes <div class=\"centerInput\"><input className=\"ARF_Input\" type=\"checkbox\" id=\"horns\" name=\"horns\"></div></p>*/}\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"WasPropDamaged\" value={\"No\"} onClick={() => setWasPropDamaged(\"No\")} id=\"WasPropDamaged\"  required />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"WasPropDamaged\" value={\"Unknown\"} onClick={() => setWasPropDamaged(\"Unknown\")} id=\"WasPropDamaged\"  required />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  17\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '9pt', textIndent: '0pt', textAlign: 'left'}}>If yes, how was the person involved in the accident/incident?</p>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Owner of property adjacent to park district\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"OwnerOfPropertyAdjacentToParkDistrict\" name=\"HowWasPersonInvolved\" value={\"OwnerOfPropertyAdjacentToParkDistrict\"} onClick={() => setHowWasPersonInvolved(\"OwnerOfPropertyAdjacentToParkDistrict\")} id=\"HowWasPersonInvolved\"   />\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Patron\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Patron\" name=\"HowWasPersonInvolved\" value={\"Patron\"} onClick={() => setHowWasPersonInvolved(\"Patron\")} id=\"HowWasPersonInvolved\"   />\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Vehicle Owner\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"VehicleOwner\" name=\"HowWasPersonInvolved\" value={\"VehicleOwner\"} onChange={() => setHowWasPersonInvolved(\"VehicleOwner\")} id=\"HowWasPersonInvolved\"   />\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Other\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Other\" name=\"HowWasPersonInvolved\" value={\"Other\"} onChange={() => setHowWasPersonInvolved(\"Other\")} id=\"HowWasPersonInvolved\"   />\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  18\n                </td>\n                {/*<td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}>18<br /></p></td>*/}\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Last name (or business name)\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamageLName\" value={PropDamageLName} onChange={(e) => setPropDamageLName(e.target.value)} id=\"PropDamageLName\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      First name (not necessary if business name)\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamageFName\" value={PropDamageFName} onChange={(e) => setPropDamageFName(e.target.value)} id=\"PropDamageFName\"   /></div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Address</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamAddress\" value={PropDamAddress} onChange={(e) => setPropDamAddress(e.target.value)} id=\"PropDamAddress\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid4\">\n                    <div className=\"ARF_s3\">\n                      City\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamCity\" value={PropDamCity} onChange={(e) => setPropDamCity(e.target.value)} id=\"PropDamCity\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      State\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamState\" value={PropDamState} onChange={(e) => setPropDamState(e.target.value)} id=\"PropDamState\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Zip Code\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamZip\" placeholder=\"00000\" pattern=\"[0-9]{5}\" value={PropDamZip} onChange={(e) => setPropDamZip(e.target.value)} id=\"PropDamZip\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Phone number\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"PropDamPhone\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" value={PropDamPhone} onChange={(e) => setPropDamPhone(e.target.value)} id=\"PropDamPhone\"   /></div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Describe the property damage</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" id=\"PropertyDamageDescription\" name=\"PropertyDamageDescription\" value={PropDamDescription} onChange={(e) => setPropDamDescription(e.target.value)} /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td colSpan={4} className=\"ARF_blue-boxes\" style={{borderRight: '3px solid #24418E'}}>\n                  <div className=\"ARF_text-left\">WITNESS INFORMATION</div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  19\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '9pt', textIndent: '0pt', textAlign: 'left'}}>If there was a witness(es) to the accident/incident, please provide the following information:</p>\n                </td>\n              </tr>\n\n\n            {/*<input type=\"checkbox\" name=\"Witness\" value={Witness} onChange={(e) => setWitness(e.target.value)} id=\"Witness\"  required />*/}\n            {/*Code does not include the yes and no options to say if there was a witness, here is the code if added*/}\n\n\n\n\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3\">\n                      Last name\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" name=\"WitnessLName\" value={WitnessLName} onChange={(e) => setWitnessLName(e.target.value)} id=\"WitnessLName\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      First name\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessFName\" value={WitnessFName} onChange={(e) => setWitnessFName(e.target.value)} id=\"WitnessFName\"   /></div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Address</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessAddress\" value={WitnessAddress} onChange={(e) => setWitnessAddress(e.target.value)} id=\"WitnessAddress\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={4} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"ARF_inputGrid4\">\n                    <div className=\"ARF_s3\">\n                      City\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessCity\" value={WitnessCity} onChange={(e) => setWitnessCity(e.target.value)} id=\"WitnessCity\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      State\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessState\" value={WitnessState} onChange={(e) => setWitnessState(e.target.value)} id=\"WitnessState\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Zip Code\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessZip\" placeholder=\"00000\"  pattern=\"[0-9]{5}\" value={WitnessZip} onChange={(e) => setWitnessZip(e.target.value)} id=\"WitnessZip\"   /></div>\n                    </div>\n                    <div className=\"ARF_s3\">\n                      Phone number\n                      <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessPhoneNum\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" value={WitnessPhoneNum} onChange={(e) => setWitnessPhoneNum(e.target.value)} id=\"WitnessPhoneNum\"   /></div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                  20\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Did witness make any statements?</p>\n\n\n\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"ARF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_s3-right\">Yes</div>\n                    <div className=\"ARF_centerInput\">\n                      <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Yes\" name=\"WitnessStatement\" value={\"Yes\"} onClick={() => setWitnessStatement(\"Yes\")} id=\"WitnessStatement\"   />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"ARF_inputGrid\">\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">No</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"No\" name=\"WitnessStatement\" value={\"No\"} onClick={() => setWitnessStatement(\"No\")} id=\"WitnessStatement\"   />\n                      </div>\n                    </div>\n                    <div className=\"ARF_inputGrid\">\n                      <div className=\"ARF_s3-right\">Unknown</div>\n                      <div className=\"ARF_centerInput\">\n                        <input className=\"ARF_Input\" type=\"radio\" defaultValue=\"Unknown\" name=\"WitnessStatement\" value={\"Unknown\"} onClick={() => setWitnessStatement(\"Unknown\")} id=\"WitnessStatement\"   />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n\n              <tr style={{height: '36pt'}}>\n                <td className=\"ARF_blue-boxes\">\n                </td>\n                <td colSpan={3} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"ARF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>If yes, what did witness say?</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessSaid\" value={WitnessSaid} onChange={(e) => setWitnessSaid(e.target.value)} id=\"WitnessSaid\"   /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"ARF_blue-boxes-bottom\">21\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"ARF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Where was witness when the accident/incident occurred?</p>\n                  <div className=\"ARF_endInput\"><input className=\"ARF_Input\" type=\"text\" name=\"WitnessLocationDuringIncident\" value={WitnessLocationDuringIncident} onChange={(e) => setWitnessLocationDuringIncident(e.target.value)} id=\"WitnessLocationDuringIncident\"   /></div>\n                </td>\n              </tr>\n            <div>\n              <button type={\"submit\"}>Submit</button>\n            </div>\n            </tbody>\n\n          </table>\n          <div className=\"ARF_bottom-space\" />\n        </div>\n          </form>\n        </div>\n\n    );\n}\n \nexport default AccidentReport;","/Users/josh/Documents/GitHub/ims/src/forms/PropertyLossReport.js",["143"],[],"import \"../css/PropertyLossReport_CSS.css\"\nimport \"../images/icons/FVSRA_ICON.png\"\nimport logo from \".//PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport {useState} from \"react\";\nimport {useNavigate} from \"react-router-dom\";\n\n\n\nconst PropertyReport = () => {\n\nconst [agencyName, setAgencyName] = useState(\"Fox Valley Special Recreation Association\");\nconst [todaysDate, setTodaysDate] = useState(\"\");\nconst [dateOfIncident, setDateOfIncident] = useState(\"\");\nconst [timeOfIncident, setTimeOfIncident] = useState(\"\");\nconst [nameOfPersonCompletingTheReport, setNameOfPersonCompletingTheReport] = useState(\"\");\nconst [titleOfPersonCompletingReport, setTitleOfPersonCompletingReport] = useState(\"\");\nconst [bizPhone, setBizPhone] = useState(\"\");\nconst [bizEmail, setBizEmail] = useState(\"\");\nconst [howDidTheIncidentOccurAndWhatPropertyWasDamaged, setHowDidTheIncidentOccurAndWhatPropertyWasDamaged] = useState(\"\");\nconst [nameOfLocation, setNameOfLocation] = useState(\"\");\nconst [streetAddressIncidentLocation, setStreetAddressIncidentLocation] = useState(\"\");\nconst [cityIncidentLocation, setCityIncidentLocation] = useState(\"\");\nconst [stateIncidentLocation, setStateIncidentLocation] = useState(\"\");\nconst [zipCode, setZipCode] = useState(\"\");\nconst [locationSpecify, setLocationSpecify] = useState(\"\");\nconst [primaryLocation, setPrimaryLocation] = useState(\"\");\nconst [estimateOfLoss, setEstimateOfLoss] = useState(0);\nconst [contactPersonFacility, setContactPersonFacility] = useState(\"\");\nconst [contactPersonEmail, setContactPersonEmail] = useState(\"\")\nconst [contactPersonPhoneNum, setContactPersonPhoneNum] = useState(\"\")\nconst [damageThirdParty, setDamageThirdParty] = useState(\"\")\nconst [personResponsibleName, setPersonResponsibleName] = useState(\"\");\nconst [personResponsibleStreetAddress, setPersonResponsibleStreetAddress] = useState(\"\");\nconst [personResponsibleCity, setPersonResponsibleCity] = useState(\"\");\nconst [personResponsibleState, setPersonResponsibleState] = useState(\"\")\nconst [zipCodePersonResponsible, setZipCodePersonResponsible] = useState(\"\")\nconst [policeInvestigationYesNoUnknown, setPoliceInvestigationYesNoUnknown] = useState(\"\");\nconst [whatPoliceAgency, setWhatPoliceAgency] = useState(\"\");\nconst [policeReportNumber, setPoliceNumber] = useState(\"\");\nconst [wereCriminalCharges, setWereCriminalCharges] = useState(\"\");\nconst navigate = useNavigate() //Like going back and forward in \"history\"/back from the previous or next page\n\n\n  const handleSubmit = (e) => { //Handles the onSubmit action of the log\n    e.preventDefault();\n\n    let propertyLossReportObj = {\n      \"Name_of_the_Agency\": agencyName,\n      \"Todays_Date\": todaysDate,\n      \"Date_of_Incident\": dateOfIncident,\n      \"Time_Of_Incident\": timeOfIncident,\n      \"Name_of_the_person_Completing_the_report\": nameOfPersonCompletingTheReport,\n      \"Title_Of_Person_Completing_the_report\": titleOfPersonCompletingReport,\n      \"Business_Phone\": bizPhone,\n      \"Business_Email\": bizEmail,\n      \"How_did_the_incident_occur_and_what_property_was_damaged\": howDidTheIncidentOccurAndWhatPropertyWasDamaged,\n      \"Name_of_location\": nameOfLocation,\n      \"Street_Address_Incident_Location\": streetAddressIncidentLocation,\n      \"State_Incident_Location\": stateIncidentLocation,\n      \"City_Incident_Location\": cityIncidentLocation,\n      \"Zip_Code\": zipCode,\n      \"Location_Specify\": locationSpecify,\n      \"Primary_Location\": primaryLocation,\n      \"Estimate_of_Loss\": estimateOfLoss,\n      \"Contact_Person_Facility\": contactPersonFacility,\n      \"Contact_Person_Email\": contactPersonEmail,\n      \"Contact_Person_Phone_Number\": contactPersonPhoneNum,\n      \"Damage_Third_Party\": damageThirdParty,\n      \"Person_Responsible_Name\": personResponsibleName,\n      \"Person_Responsible_Street_Address\": personResponsibleStreetAddress,\n      \"Person_Responsible_City\": personResponsibleCity,\n      \"Person_Responsible_State\": personResponsibleState,\n      \"Zip_Code_Person_Responsible\": zipCodePersonResponsible,\n      \"Police_Investigation_Yes_No_Unknown\": policeInvestigationYesNoUnknown,\n      \"What_Police_Agency\": whatPoliceAgency,\n      \"Police_Report_Number\": policeReportNumber,\n      \"Were_Criminal_Charges\": wereCriminalCharges\n    }\n\n    fetch('https://api.foxvalleyspecialrec.com/fvsra/propertyLossReport', {\n      method: 'POST',\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(propertyLossReportObj)\n    }).then(() => {\n      navigate(\"/submitted\") //Redirects page\n    })\n\n  }\n\n    return (\n        <div className=\"PLRF_entire-page\">\n        <div className=\"PLRF_top-space\" />\n        <div className=\"PLRF_page-head\">\n          <div className=\"PLRF_page-head-grid\">\n            <div>\n              <p style={{textIndent: '0pt', textAlign: 'left'}}><span><img alt=\"image\" height={68} src={logo} width={222} /></span>\n              </p>\n            </div>\n            <div>\n              <table className=\"PLRF_table\" style={{borderCollapse: 'collapse'}} cellSpacing={0}>\n                <tbody><tr style={{height: '16pt'}}>\n                    <td style={{width: '315pt', borderRightStyle: 'solid', borderRightWidth: '1pt', borderRightColor: 'white'}} rowSpan={3} bgcolor=\"#25408F\"><p className=\"PLRF_head-text4\" style={{paddingTop: '1pt', paddingLeft: '1pt', paddingRight: '4pt', textIndent: '0pt', textAlign: 'center'}}>\n                      </p><h1 style={{textIndent: '0pt', lineHeight: '27pt', textAlign: 'center'}}>Property Loss Report</h1>\n                      <p className=\"PLRF_s1\" style={{textIndent: '0pt', lineHeight: '9pt', textAlign: 'center'}}>\n                        (For damage to agency property)\n                      </p>\n                      <p style={{paddingTop: '2pt', textIndent: '0pt', textAlign: 'center'}}>\n                        Attorney/Client Privileged Document\n                      </p>\n                    </td>\n                    <td style={{width: '57pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderRightStyle: 'solid', borderRightWidth: '1pt'}} bgcolor=\"#25408F\"><p className=\"PLRF_head-text2\" style={{paddingLeft: '7pt', paddingRight: '7pt', textIndent: '0pt', lineHeight: '15pt', textAlign: 'center'}}>\n                      </p><h3 style={{paddingTop: '2pt', paddingLeft: '8pt', textIndent: '0pt', textAlign: 'left'}}>Form</h3>\n                      <h2 style={{paddingTop: '3pt', paddingLeft: '14pt', textIndent: '0pt', textAlign: 'left'}}>03</h2>\n                    </td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n        </div>\n        <div className=\"PLRF_header-body-space\" />\n        <form onSubmit={handleSubmit}>\n          <table className=\"PLRF_form-table\">\n            <tbody><tr style={{height: '21pt'}}>\n                <td className=\"PLRF_blue-boxes-top\">\n                  1\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Agency name</p>\n                  <input className=\"PLRF_Input\" type=\"text\" value={agencyName} onChange={(e) => setAgencyName(e.target.value)} id=\"Agency_Name\" name=\"Agency_Name\" required />\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Today’s date</p>\n                  <input className=\"PLRF_Input\" type=\"date\" id=\"Todays_Date\" value={todaysDate} onChange={(e) => setTodaysDate(e.target.value)} name=\"Today's_Date\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" />\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  2\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Date of incident (mm/dd/yyyy)</p>\n                  <input className=\"PLRF_Input\" type=\"date\" id=\"Date_of_Incident\" value={dateOfIncident} onChange={(e) => setDateOfIncident(e.target.value)} name=\"Date_of_Incident\" defaultValue min=\"2021-01-01\" max=\"2050-01-01\" />\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Time of incident (hh/mm,\n                    a.m./p.m.)</p>\n                  <input className=\"PLRF_Input\" type=\"time\" value={timeOfIncident} onChange={(e) => setTimeOfIncident(e.target.value)} id=\"Time_of_Incident\" name=\"Time_of_Incident\" />\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  3\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Name of person completing the report</p>\n                  <input className=\"PLRF_Input\" type=\"text\" value={nameOfPersonCompletingTheReport} onChange={(e) => setNameOfPersonCompletingTheReport(e.target.value)} id=\"Name_of_person_completing_the_report\" name=\"Name_of_person_completing_the_report\" required />\n                </td><td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Title of person completing report</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={titleOfPersonCompletingReport} onChange={(e) => setTitleOfPersonCompletingReport(e.target.value)} id=\"Title_of_person_completing_report\" name required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '21pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  4\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Business phone</p>\n                  <input className=\"PLRF_Input\" type=\"tel\" id=\"Business_phone\" value={bizPhone} onChange={(e) => setBizPhone(e.target.value)} name=\"phone\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" />\n                </td><td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E'}}>\n                  <p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Business email</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={bizEmail} onChange={(e) => setBizEmail(e.target.value)} id=\"Business_email\" name required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  5\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>How did the incident\n                    occur and what property was damaged? (Provide a brief factual summary.)</p>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={howDidTheIncidentOccurAndWhatPropertyWasDamaged} onChange={(e) => setHowDidTheIncidentOccurAndWhatPropertyWasDamaged(e.target.value)} id=\"How_did_the_incident_occur_and_what_property_was_damaged\" name=\"How_did_the_incident_occur_and_what_property_was_damaged\" required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '20pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"PLRF_Input\" type=\"text\" id=\"HowDidIncidentOccur2\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '4pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"PLRF_Input\" type=\"text\" id=\"HowDidIncidentOccur3\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  6\n                </td>\n                <td colSpan={3} style={{borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Name of the location (park, pool,\n                    community center; <span className=\"PLRF_s7\">Ex. Smith Pool, Johnson Community Center</span>) or nearest intersection\n                  </p>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>where the incident occurred.</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={nameOfLocation} onChange={(e) => setNameOfLocation(e.target.value)} id=\"NameOfLocation\" name=\"NameOfLocation\" required /></div>\n                </td>\n              </tr>\n              <tr style={{height: '19pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  7\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Is there an address\n                    for incident location? If yes, please provide the following:</p></td>\n              </tr>\n              <tr style={{height: '32pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{paddingTop: '4pt', textIndent: '0pt', textAlign: 'left'}}>Street address</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={streetAddressIncidentLocation} onChange={(e) => setStreetAddressIncidentLocation(e.target.value)} id=\"StreetAddressIncidentLocation\" name=\"StreetAddressIncidentLocation\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>City</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={cityIncidentLocation} onChange={(e) => setCityIncidentLocation(e.target.value)} id=\"CityIncidentLocation\" name=\"CityIncidentLocation\" /></div>\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'none', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>State</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={stateIncidentLocation} onChange={(e) => setStateIncidentLocation(e.target.value)} id=\"StateIncidentLocation\" name=\"StateIncidentLocation\" /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Zip code</p>\n                  <input className=\"PLRF_Input\" type=\"tel\" id=\"ZipCode\" value={zipCode} onChange={(e) => setZipCode(e.target.value)} name=\"ZipCode\" placeholder=\"00000\" pattern=\"[0-9]{5}\" />\n                </td>\n              </tr>\n              <tr style={{height: '5pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n              </tr>\n              <tr style={{height: '24pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  8\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{paddingLeft: '1pt', textIndent: '0pt', textAlign: 'left'}}>Location (Specify the\n                    exact type of location/facility damaged, listing multiple locations/facilities if necessary. <span className=\"PLRF_s7\">Ex. mainte-</span></p>\n                  <p className=\"PLRF_s7\" style={{paddingLeft: '1pt', textIndent: '0pt', textAlign: 'left'}}>nance garage, sports field<span className=\"PLRF_s3\">)</span></p>\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={locationSpecify} onChange={(e) => setLocationSpecify(e.target.value)} id=\"LocationSpecify\" name=\"LocationSpecify\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '6pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p>\n                  {/*                <div class=\"endInput\"><input className=\"PLRF_Input\" type=\"text\" id=\"LocationSpecify2\" name=\"\"></div>*/}\n                </td>\n              </tr>\n              <tr style={{height: '24pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  9\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Primary location (Identify the exact\n                    area of damage. <span className=\"PLRF_s7\">Ex. tool storage, batting cage</span>)</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={primaryLocation} onChange={(e) => setPrimaryLocation(e.target.value)} id=\"PrimaryLocation\" name=\"PrimaryLocation\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  10\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Estimate of loss</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" id=\"EstimateOfLoss\" value={estimateOfLoss} onChange={(e) => setEstimateOfLoss(e.target.value)} name=\"EstimateOfLoss\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '24pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  11\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Contact person at facility</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={contactPersonFacility} onChange={(e) => setContactPersonFacility(e.target.value)} id=\"ContactPersonFacility\" name=\"ContactPersonFacility\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  12\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '2pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Contact person’s email</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={contactPersonEmail} onChange={(e) => setContactPersonEmail(e.target.value)} id=\"ContactPersonEmail\" name=\"ContactPersonEmail\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  13\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '2pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Contact person’s phone number</p>\n                  <input className=\"PLRF_Input\" type=\"tel\" value={contactPersonPhoneNum} onChange={(e) => setContactPersonPhoneNum(e.target.value)} id=\"ContactPersonPhoneNumber\" name=\"ContactPersonPhoneNumber\" placeholder=\"000-000-0000\" pattern=\"[0-9]{3}-[0-9]{3}-[0-9]{4}\" />\n                </td>\n              </tr>\n              <tr style={{height: '22pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  14\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>Was damage caused by third-party\n                    (non-agency) individual?</p></td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <div className=\"PLRF_inputGrid\">\n                    <div className=\"PLRF_s3-right\">Yes</div>\n                    <div className=\"PLRF_centerInput\">\n                      <input className=\"PLRF_Input\" type=\"radio\" value=\"Yes\" checked={damageThirdParty === \"Yes\"} onClick={() => setDamageThirdParty(\"Yes\")} defaultValue=\"Yes\" id=\"DamageThirdPartyYes\" name=\"DamageThirdParty\" />\n                    </div>\n                  </div>\n                  {/*                <p class=\"s3\" style=\"text-indent: 0pt;line-height: 10pt;text-align: right;\">Yes <div class=\"centerInput\"><input className=\"PLRF_Input\" type=\"checkbox\" id=\"horns\" name=\"horns\"></div></p>*/}\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <div className=\"PLRF_inputGrid\">\n                    <div className=\"PLRF_inputGrid\">\n                      <div className=\"PLRF_s3-right\">No</div>\n                      <div className=\"PLRF_centerInput\">\n                        <input className=\"PLRF_Input\" type=\"radio\" value={\"No\"} checked={damageThirdParty === \"No\"} onClick={() => setDamageThirdParty(\"No\")} defaultValue=\"No\" id=\"DamageThirdPartyNo\" name=\"DamageThirdParty\" />\n                      </div>\n                    </div>\n                    <div className=\"PLRF_inputGrid\">\n                      <div className=\"PLRF_s3-right\">Unknown</div>\n                      <div className=\"PLRF_centerInput\">\n                        <input className=\"PLRF_Input\" type=\"radio\" value={\"Unknown\"} onClick={() => setDamageThirdParty(\"Unknown\")} defaultValue=\"Unknown\" id=\"DamageThirdPartyUnknown\" name=\"DamageThirdParty\" defaultChecked />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '27pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  15\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{paddingRight: '9pt', textIndent: '0pt', textAlign: 'left'}}>Has the party\n                    responsible for damage been identified? If yes, provide the following contact information for the person or\n                    persons identified:</p></td>\n              </tr>\n              <tr style={{height: '36pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"PLRF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Name</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={personResponsibleName} onChange={(e) => setPersonResponsibleName(e.target.value)} id=\"PersonResponsibleName\" name=\"PersonResponsibleName\" /></div>\n                </td>\n                <td colSpan={2} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Street address</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={personResponsibleStreetAddress} onChange={(e) => setPersonResponsibleStreetAddress(e.target.value)} id=\"PersonResponsibleStreetAddress\" name=\"PersonResponsibleStreetAddress\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '29pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"PLRF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>City</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={personResponsibleCity} onChange={(e) => setPersonResponsibleCity(e.target.value)} id=\"PersonResponsibleCity\" name=\"PersonResponsibleCity\" /></div>\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'none', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20'}}>\n                  <p className=\"PLRF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>State</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={personResponsibleState} onChange={(e) => setPersonResponsibleState(e.target.value)} id=\"PersonResponsibleState\" name=\"PersonResponsibleState\" /></div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#231F20', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{paddingTop: '1pt', textIndent: '0pt', textAlign: 'left'}}>Zip code</p>\n                  <input className=\"PLRF_Input\" type=\"tel\" id=\"ZipCodePersonResponsible\" value={zipCodePersonResponsible} onChange={(e) => setZipCodePersonResponsible(e.target.value)} name=\"ZipCodePersonResponsible\" placeholder=\"00000\" pattern=\"[0-9]{5}\" />\n                </td>\n              </tr>\n              <tr style={{height: '7pt'}}>\n                <td bgcolor=\"#24418E\" style={{width: '14pt'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#231F20', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p style={{textIndent: '0pt', textAlign: 'left'}}><br /></p></td>\n              </tr>\n              <tr style={{height: '25pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  16\n                </td>\n                <td style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Has a police agency conducted an investigation?</p>\n                </td>\n                <td style={{width: '41pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s8\" style={{textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"PLRF_inputGrid\">\n                    <div className=\"PLRF_s3-right\">Yes</div>\n                    <div className=\"PLRF_centerInput\">\n                      <input className=\"PLRF_Input\" type=\"radio\" onChange={(e) => setPoliceInvestigationYesNoUnknown(\"Yes\")} defaultValue=\"Yes\" id=\"PoliceInvestigationYes\" name=\"PoliceInvestigation\" />\n                    </div>\n                  </div>\n                </td>\n                <td style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{paddingRight: '33pt', textIndent: '0pt', textAlign: 'right'}}>\n                  </p><div className=\"PLRF_inputGrid\">\n                    <div className=\"PLRF_inputGrid\">\n                      <div className=\"PLRF_s3-right\">No</div>\n                      <div className=\"PLRF_centerInput\">\n                        <input className=\"PLRF_Input\" type=\"radio\" defaultValue=\"No\" onChange={(e) => setPoliceInvestigationYesNoUnknown(\"No\")} id=\"PoliceInvestigationNo\" name=\"PoliceInvestigation\" />\n                      </div>\n                    </div>\n                    <div className=\"PLRF_inputGrid\">\n                      <div className=\"PLRF_s3-right\">Unknown</div>\n                      <div className=\"PLRF_centerInput\">\n                        <input className=\"PLRF_Input\" type=\"radio\" defaultValue=\"Unknown\" onChange={(e) => setPoliceInvestigationYesNoUnknown(\"Unknown\")} id=\"PoliceInvestigationUnknown\" name=\"PoliceInvestigation\" defaultChecked />\n                      </div>\n                    </div>\n                  </div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes\">\n                  17\n                </td>\n                <td colSpan={2} style={{width: '283pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{paddingLeft: '1pt', textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>What police\n                    agency investigated the incident?</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" id=\"WhatPoliceAgency\" value={whatPoliceAgency} onChange={(e) => setWhatPoliceAgency(e.target.value)} name=\"WhatPoliceAgency\" /></div>\n                </td>\n                <td colSpan={1} style={{width: '202pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}>\n                  <p className=\"PLRF_s3\" style={{textIndent: '0pt', lineHeight: '10pt', textAlign: 'left'}}>What is the police report\n                    number?</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={policeReportNumber} onChange={(e) => setPoliceNumber(e.target.value)} id=\"PoliceReportNumber\" name=\"PoliceReportNumber\" /></div>\n                </td>\n              </tr>\n              <tr style={{height: '23pt'}}>\n                <td className=\"PLRF_blue-boxes-bottom\">\n                  18\n                </td>\n                <td colSpan={3} style={{width: '526pt', borderTopStyle: 'solid', borderTopWidth: '1pt', borderTopColor: '#24418E', borderLeftStyle: 'solid', borderLeftWidth: '1pt', borderLeftColor: '#24418E', borderBottomStyle: 'solid', borderBottomWidth: '1pt', borderBottomColor: '#24418E', borderRightStyle: 'solid', borderRightWidth: '2pt', borderRightColor: '#24418E'}}><p className=\"PLRF_s3\" style={{textIndent: '0pt', textAlign: 'left'}}>Were criminal charges brought against\n                    the responsible party? If yes, what were the charges?</p>\n                  <div className=\"PLRF_endInput\"><input className=\"PLRF_Input\" type=\"text\" value={wereCriminalCharges} onChange={(e) => setWereCriminalCharges(e.target.value)} id=\"WereCriminalCharges\" name=\"WereCriminalCharges\" /></div>\n                </td>\n              </tr>\n            </tbody></table>\n          <div className=\"PLRF_center-text\">\n            <button name=\"submitPropertyLossReport\" onclick=\"submitBtn()\">Submit</button>\n          </div>\n        </form>\n        <div className=\"PLRF_bottom-space\" />\n      </div>\n     );\n}\n \nexport default PropertyReport;","/Users/josh/Documents/GitHub/ims/src/forms/VehicleAccidentReport.js",["144","145","146","147","148"],[],"import \"../css/VehicleAccidentReport.css\"\nimport \"../images/icons/FVSRA_ICON.png\"\nimport logo from \".//PDRMA Form 03 Property Loss Report_files/Image_001.jpg\"\nimport {useState} from \"react\";\nimport {useNavigate} from \"react-router-dom\";\n\nconst VehicleReport = () => {\n  const [AgencyName2_1, setAgencyName2_1] = useState('Fox Valley Special Recreation Association');\n  const [TodaysDate2_1, setTodaysDate2_1] = useState('');\n  const [DateIncident2_2, setDateIncident2_2] = useState('');\n  const [TimeIncident2_2, setTimeIncident2_2] = useState('');\n  const [Name2_3, setName2_3] = useState('');\n  const [Title2_3, setTitle2_3] = useState('');\n  const [Business_Phone2_4, setBusiness_Phone2_4] = useState('');\n  const [Business_Email2_4, setBusiness_Email2_4] = useState('');\n  const [Incident_Occur2_5, setIncident_Occur2_5] = useState('');\n  const [NameOfLocation2_6, setNameOfLocation2_6] = useState('');\n  const